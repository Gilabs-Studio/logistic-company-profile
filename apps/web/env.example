# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080

# Environment
NODE_ENV=development

# n8n Automation (self-hosted or n8n.cloud webhook URL)
NEXT_PUBLIC_N8N_LEADS_WEBHOOK_URL=https://your-instance.n8n.cloud/webhook/gims-generate-leads

# Third-party API keys for n8n lead-generation workflows.
# These are SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix) — never exposed to the browser.
# The /api/n8n/proxy route injects them into every webhook payload automatically.
# Callers can still supply their own key via the webhook payload; those values take precedence.
APOLLO_API_KEY=          # Apollo.io API key  — app.apollo.io → Settings → API
SERPER_API_KEY=          # Serper.dev API key — serper.dev → Dashboard
APIFY_API_KEY=           # Apify API key      — console.apify.com → Settings → Integrations
